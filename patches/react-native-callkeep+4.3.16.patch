+    private static Intent createAuthorizedCallLaunchIntent(Context context) {
+        String packageName = context.getApplicationContext().getPackageName();
+        Intent launchIntent = context.getPackageManager().getLaunchIntentForPackage(packageName);
+        if (launchIntent == null) return null;
+
+        Intent focusIntent = launchIntent.cloneFilter();
+        String launchToken = UUID.randomUUID().toString();
+        SharedPreferences launchPreferences = context.getSharedPreferences(
+                CALL_LAUNCH_PREFERENCES,
+                Context.MODE_PRIVATE
+        );
+        boolean tokenStored;
+        synchronized (RNCallKeepModule.class) {
+            Set<String> storedTokens = launchPreferences.getStringSet(CALL_LAUNCH_TOKEN_KEY, null);
+            Set<String> authorizedTokens = storedTokens == null
+                    ? new HashSet<>()
+                    : new HashSet<>(storedTokens);
+            authorizedTokens.add(launchToken);
+            tokenStored = launchPreferences
+                    .edit()
+                    .putStringSet(CALL_LAUNCH_TOKEN_KEY, authorizedTokens)
+                    .putBoolean(CALL_SCREEN_ACTIVE_KEY, true)
+                    .commit();
+        }
+        if (!tokenStored) {
+            Log.w(TAG, "[RNCallKeepModule] could not authorize the call-screen launch.");
+        }
+        focusIntent.putExtra(EXTRA_CALL_LAUNCH_TOKEN, launchToken);
+        return focusIntent;
+    }
+
+    public static void openCallAppForIncomingCall(Context context) {
