+            try {
+                if (!incomingRingtone.isPlaying()) incomingRingtone.play();
+            } catch (RuntimeException error) {
+                Log.w(TAG, "[RNCallKeepModule][startIncomingRingtone] could not resume the ringtone", error);
+                stopIncomingRingtonePlayback(nativeCallId);
+            }
+            return;
+        }
+
+        stopIncomingRingtonePlayback(null);
+        Context context = getAppContext();
+        if (context == null) {
+            Log.w(TAG, "[RNCallKeepModule][startIncomingRingtone] no application context found.");
+            return;
+        }
+
+        Uri ringtoneUri = RingtoneManager.getDefaultUri(RingtoneManager.TYPE_RINGTONE);
+        if (ringtoneUri == null) {
+            Log.d(TAG, "[RNCallKeepModule][startIncomingRingtone] the system ringtone is set to silent.");
+            return;
+        }
+        Ringtone ringtone = RingtoneManager.getRingtone(context, ringtoneUri);
