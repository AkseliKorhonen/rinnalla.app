# Filled by `npx convex dev` after you connect this project to a Convex deployment.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=

# Password reset email delivery. Set these in the Convex deployment environment
# as well as locally for development.
AUTH_RESEND_KEY=
AUTH_RESEND_FROM="Vaari Tablet <support@example.com>"

# Optional Cloudflare TURN credentials for browser video calls.
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
